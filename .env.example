# --- Server ---
NODE_ENV=development
HOST=0.0.0.0
PORT=3005

# --- Postgres (Neon free tier in prod; local docker in dev) ---
DATABASE_URL=postgres://noder:noder@localhost:5433/noder

# --- Redis (Upstash free tier in prod; local docker in dev) ---
REDIS_URL=redis://localhost:6380

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- OAuth2 (Google stub) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3005/api/v1/auth/google/callback

# --- Frontend (used to redirect browser OAuth flows back to the app) ---
FRONTEND_URL=http://localhost:3002

# --- AI (Claude) ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096

# --- Embeddings (Voyage AI free tier) ---
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024

# --- Storage (Cloudinary free tier) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- CORS (comma-separated origins; "*" allows all — dev only) ---
CORS_ORIGINS=http://localhost:3002

# --- Rate limiting ---
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
